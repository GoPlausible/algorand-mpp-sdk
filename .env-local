# Copy this file to .env and fill in the values.
# Used by integration tests: pnpm test:integration

# Fee payer key — accepts either format:
#   - 25-word Algorand mnemonic (space-separated)
#   - Base64-encoded private key (44 chars, ends with =)
FEE_PAYER_KEY=

# Recipient address for test payments.
# If not set, defaults to the fee payer address (self-payment).
RECIPIENT=
