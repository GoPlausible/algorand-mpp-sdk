# ── Algorand MPP Demo Server Configuration ──

# Algorand address that receives payments (58-char base32 address)
# If not set, a zero address is used (demo only)
RECIPIENT=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAY5HFKQ

# CAIP-2 network identifier
# TestNet: algorand:SGO1GKSzyE7IEPItTxCByw9x8FmnrCDexi9/cOUJOiI=
# MainNet: algorand:wGHE2Pwdvd7S12BL5FaOP20EGYesN73ktiC1qzkkit8=
NETWORK=algorand:SGO1GKSzyE7IEPItTxCByw9x8FmnrCDexi9/cOUJOiI=

# Secret key for mppx challenge signing (hex string)
# If not set, a random key is generated on each startup
# Generate a random 32-byte hex key
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MPP_SECRET_KEY=

# Fee payer key for fee sponsorship mode
# When set, the server pays transaction fees on behalf of clients
# Accepts either:
#   - 25-word Algorand mnemonic (space-separated)
#   - Base64-encoded private key (44 chars)
# The account needs a small ALGO balance for fees (~0.1 ALGO)
# Fund via: https://lora.algokit.io/testnet/fund
FEE_PAYER_KEY=

# Server port
PORT=3000
